# ── Site ──────────────────────────────────────────────────────────
# Base URL of the deployed site. Used for canonical URLs, OG tags, sitemap
# and structured data. Never hard-code the domain anywhere else in the app.
NEXT_PUBLIC_SITE_URL=https://spark-solutions.co.uk
NEXT_PUBLIC_SITE_NAME=Spark Solutions

# ── Pricing ──────────────────────────────────────────────────────
# Monthly platform fee and setup fee, in GBP. Read at render time so
# pricing can be changed without a code deploy. No decimals.
NEXT_PUBLIC_MONTHLY_PRICE=325
NEXT_PUBLIC_SETUP_FEE=0

# ── Email (Resend) ──────────────────────────────────────────────
# API key from https://resend.com/api-keys. Used server-side only by
# app/api/demo/route.ts to send the prospect confirmation and the
# internal notification email.
RESEND_API_KEY=
# Address demo request notifications are sent to.
DEMO_NOTIFICATION_EMAIL=jason@yourdomain.com
# "From" address for outbound mail. Must be on a domain verified in Resend.
RESEND_FROM_EMAIL=Spark Solutions <hello@spark-solutions.co.uk>

# ── Analytics ────────────────────────────────────────────────────
# Google Tag Manager container ID, e.g. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=
# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_ID=
